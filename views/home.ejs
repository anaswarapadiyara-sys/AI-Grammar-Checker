<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>AI Grammar Genius</title>

    <!-- Bootstrap -->

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">

    <!-- Google Font -->

    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">

    <!-- Custom CSS -->

    <link rel="stylesheet" href="/css/style.css">

</head>

<body>

    <div class="background-blur"></div>

    <div class="container py-5">

        <!-- HEADER -->

        <div class="text-center mb-5">

            <div class="robot-icon">

                <i class="fas fa-robot"></i>

            </div>

            <h1 class="main-title">

                AI Grammar <span>Genius</span>

            </h1>

            <p class="subtitle">

                Improve your writing instantly using Artificial Intelligence

            </p>

        </div>

        <!-- MAIN -->

        <div class="row g-4">

            <!-- LEFT -->

            <div class="col-lg-6">

                <div class="glass-card">

                    <h3>

                        <i class="fa-solid fa-keyboard me-2"></i>

                        Your Text

                    </h3>

                    <p>

                        Enter or paste your text below.

                    </p>

                    <form action="/correct" method="POST">

                        <textarea class="form-control custom-textarea" name="text" id="textInput" rows="12"
                            maxlength="5000" placeholder="Start typing..."><%= originalText || "" %></textarea>

                        <div class="d-flex justify-content-between mt-3">

                            <small id="count">0 / 5000</small>

                            <small>AI Powered</small>

                        </div>

                        <button class="btn ai-btn w-100 mt-4">

                            <i class="fas fa-wand-magic-sparkles me-2"></i>

                            Correct Grammar

                        </button>

                    </form>

                </div>

            </div>

            <!-- RIGHT -->

            <div class="col-lg-6">

                <div class="glass-card">

                    <div class="d-flex justify-content-between align-items-center">

                        <h3>

                            <i class="fas fa-check-circle text-success me-2"></i>

                            Corrected Text

                        </h3>

                        <% if(corrected){ %>

                            <button class="btn btn-sm btn-outline-light" id="copyBtn">

                                Copy

                            </button>

                            <% } %>

                    </div>

                    <div class="output-box mt-4" id="output">

                        <% if(corrected){ %>

                            <%= corrected %>

                                <% } else { %>

                                    <div class="empty">

                                        <i class="fas fa-magic"></i>

                                        <p>Your corrected text will appear here.</p>

                                    </div>

                                    <% } %>

                    </div>

                </div>

            </div>

        </div>

        <!-- FEATURES -->

        <div class="row mt-5 g-4">

            <div class="col-md-4">

                <div class="feature-box">

                    <i class="fas fa-bolt"></i>

                    <h4>Lightning Fast</h4>

                    <p>Get corrections in seconds.</p>

                </div>

            </div>

            <div class="col-md-4">

                <div class="feature-box">

                    <i class="fas fa-brain"></i>

                    <h4>AI Powered</h4>

                    <p>Advanced AI understands your writing.</p>

                </div>

            </div>

            <div class="col-md-4">

                <div class="feature-box">

                    <i class="fas fa-lock"></i>

                    <h4>Secure</h4>

                    <p>Your text stays private.</p>

                </div>

            </div>

        </div>

    </div>

    <script src="/js/script.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>